DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/devsbet?schema=public"
JWT_SECRET="change-this-secret-in-production"
PORT=5000
# Front (Next) origin. CORS with credentials requires a specific origin.
WEB_ORIGIN="http://localhost:3000"
# Match settlement queue (BullMQ producer). Must point to the same Redis as the worker.
REDIS_URL="redis://localhost:6379"
# Manual Pix deposit destination (the owner's account shown to users topping up).
WALLET_PIX_KEY="owner@example.com"
WALLET_PIX_KEY_TYPE="email"
WALLET_BENEFICIARY_NAME="Devs-Bet"
